# Copy to .env and fill in your values

# Backend API (use proxy in dev: leave empty to use same origin /api via Vite proxy)
VITE_API_BASE_URL=

# Cloudinary — frontend uploads files directly, then sends file_url to Django
VITE_CLOUDINARY_CLOUD_NAME=dhinxvbpv
VITE_CLOUDINARY_UPLOAD_PRESET=medical_unsigned
# Optional: folder prefix for uploads
VITE_CLOUDINARY_FOLDER=medical-coder/uploads
